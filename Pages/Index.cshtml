@page
@model IndexModel
@{
    ViewData["Title"] = "Browse Snippets";
    var hasFilters = !string.IsNullOrEmpty(Model.Query) || Model.SelectedLanguages.Count > 0 || Model.SelectedTags.Count > 0;
}

<div class="page-header">
    <h1>Snippets</h1>
    <span style="color:#8b949e;font-size:0.9rem;">@Model.Snippets.Count snippet@(Model.Snippets.Count == 1 ? "" : "s")</span>
</div>

<form method="get" class="search-bar">
    <input type="search" name="q" value="@Model.Query" placeholder="Search title, description, code…" />

    <details class="filter-picker" id="langPicker">
        <summary>@(Model.SelectedLanguages.Count > 0 ? $"Language ({Model.SelectedLanguages.Count})" : "Language")</summary>
        <div class="filter-picker-menu">
            @foreach (var lang in Model.Languages)
            {
                <label>
                    <input type="checkbox" name="language" value="@lang"
                           checked="@(Model.SelectedLanguages.Any(l => l.Equals(lang, StringComparison.OrdinalIgnoreCase)) ? "checked" : null)"
                           onchange="this.form.submit()" />
                    @lang
                </label>
            }
        </div>
    </details>

    <details class="filter-picker" id="tagPicker">
        <summary>@(Model.SelectedTags.Count > 0 ? $"Tags ({Model.SelectedTags.Count})" : "Tags")</summary>
        <div class="filter-picker-menu">
            @foreach (var tag in Model.AllTags)
            {
                <label>
                    <input type="checkbox" name="tag" value="@tag"
                           checked="@(Model.SelectedTags.Any(t => t.Equals(tag, StringComparison.OrdinalIgnoreCase)) ? "checked" : null)"
                           onchange="this.form.submit()" />
                    @tag
                </label>
            }
        </div>
    </details>

    <button type="submit" class="btn btn-secondary">Search</button>
    @if (hasFilters)
    {
        <a href="/" class="btn btn-secondary">Clear</a>
    }
</form>

@if (hasFilters)
{
    <div class="active-filters">
        <span class="active-filters-label">Active filters:</span>
        @if (!string.IsNullOrEmpty(Model.Query))
        {
            <span class="active-filter-chip">search: "@Model.Query"</span>
        }
        @if (Model.SelectedLanguages.Count > 0)
        {
            <span class="active-filter-chip">language: @string.Join(", ", Model.SelectedLanguages)</span>
        }
        @if (Model.SelectedTags.Count > 0)
        {
            <span class="active-filter-chip">tags: @string.Join(", ", Model.SelectedTags)</span>
        }
    </div>
}

@if (Model.Snippets.Count == 0)
{
    <div class="empty-state">
        <p>No snippets found.</p>
        <a href="/Snippets/Add" class="btn btn-primary">Add your first snippet</a>
    </div>
}
else
{
    <div class="snippets-grid">
        @foreach (var s in Model.Snippets)
        {
            <div class="snippet-card">
                <div>
                    <a href="/Snippets/Detail/@s.Id" style="font-weight:600;color:#e6edf3;">@s.Title</a>
                    @if (!string.IsNullOrEmpty(s.Description))
                    {
                        <div class="meta">@s.Description</div>
                    }
                    <div class="tags">
                        @foreach (var tag in s.Tags)
                        {
                            <span class="tag">@tag</span>
                        }
                    </div>
                    <div class="meta" style="margin-top:0.5rem;">Updated @s.UpdatedAt.ToString("MMM d, yyyy")</div>
                </div>
                <div style="flex-shrink:0;">
                    <span class="lang-badge">@s.Language</span>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <script>
        // Re-open picker dropdowns that have active selections after a page reload
        const params = new URLSearchParams(location.search);
        if (params.has('language')) document.getElementById('langPicker').open = true;
        if (params.has('tag')) document.getElementById('tagPicker').open = true;
    </script>
}
