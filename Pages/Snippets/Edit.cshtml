@page "{id}"
@model SnippetsWebsite.Pages.Snippets.EditModel
@{
    ViewData["Title"] = "Edit — " + Model.Input.Title;
}

<div style="margin-bottom:0.75rem;">
    <a href="/Snippets/Detail/@Model.SnippetId" style="color:#8b949e;font-size:0.875rem;">← Back to snippet</a>
</div>

<div class="page-header">
    <h1>Edit Snippet</h1>
</div>

<form method="post" style="max-width:680px;">
    <input type="hidden" name="id" value="@Model.SnippetId" />

    <div class="form-group">
        <label asp-for="Input.Title">Title</label>
        <input asp-for="Input.Title" type="text" />
        <span asp-validation-for="Input.Title" style="color:#f85149;font-size:0.8rem;"></span>
    </div>

    <div class="form-group">
        <label asp-for="Input.Language">Language</label>
        <input asp-for="Input.Language" type="text" />
        <span asp-validation-for="Input.Language" style="color:#f85149;font-size:0.8rem;"></span>
    </div>

    <div class="form-group">
        <label asp-for="Input.Description">Description <span style="color:#8b949e;">(optional)</span></label>
        <input asp-for="Input.Description" type="text" />
    </div>

    <div class="form-group">
        <label asp-for="Input.TagsRaw">Tags <span style="color:#8b949e;">(comma-separated)</span></label>
        <input asp-for="Input.TagsRaw" type="text" />
    </div>

    <div class="form-group">
        <label asp-for="Input.Code">Code</label>
        <textarea asp-for="Input.Code" rows="16"></textarea>
        <span asp-validation-for="Input.Code" style="color:#f85149;font-size:0.8rem;"></span>
    </div>

    <div class="actions">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a href="/Snippets/Detail/@Model.SnippetId" class="btn btn-secondary">Cancel</a>
    </div>
</form>
