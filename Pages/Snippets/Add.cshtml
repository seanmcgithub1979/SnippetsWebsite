@page
@model SnippetsWebsite.Pages.Snippets.AddModel
@{
    ViewData["Title"] = "New Snippet";
}

<div style="margin-bottom:0.75rem;">
    <a href="/" style="color:#8b949e;font-size:0.875rem;">← Back to snippets</a>
</div>

<div class="page-header">
    <h1>New Snippet</h1>
</div>

<form method="post" style="max-width:680px;">
    <div class="form-group">
        <label asp-for="Input.Title">Title</label>
        <input asp-for="Input.Title" type="text" placeholder="e.g. Retry with exponential backoff" />
        <span asp-validation-for="Input.Title" style="color:#f85149;font-size:0.8rem;"></span>
    </div>

    <div class="form-group">
        <label asp-for="Input.Language">Language</label>
        <input asp-for="Input.Language" type="text" placeholder="e.g. csharp, python, bash" />
        <span asp-validation-for="Input.Language" style="color:#f85149;font-size:0.8rem;"></span>
    </div>

    <div class="form-group">
        <label asp-for="Input.Description">Description <span style="color:#8b949e;">(optional)</span></label>
        <input asp-for="Input.Description" type="text" placeholder="Short summary of what this does" />
    </div>

    <div class="form-group">
        <label asp-for="Input.TagsRaw">Tags <span style="color:#8b949e;">(comma-separated, optional)</span></label>
        <input asp-for="Input.TagsRaw" type="text" placeholder="e.g. async, http, utility" />
    </div>

    <div class="form-group">
        <label asp-for="Input.Code">Code</label>
        <textarea asp-for="Input.Code" rows="16" placeholder="Paste your snippet here…"></textarea>
        <span asp-validation-for="Input.Code" style="color:#f85149;font-size:0.8rem;"></span>
    </div>

    <div class="actions">
        <button type="submit" class="btn btn-primary">Save Snippet</button>
        <a href="/" class="btn btn-secondary">Cancel</a>
    </div>
</form>
